<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Augustus Wallpaper</string>
    <string name="asset_selector_instructions">"Augustus Live Wallpaper needs the original Caesar 3 files. Copy your Caesar 3 folder to this device, then tap the button below to select it. The files are copied into the app\'s private storage so the wallpaper can read them.\n\nAfter the copy finishes, set Augustus as your live wallpaper from your launcher\'s wallpaper picker."</string>
    <string name="asset_selector_button">Select Caesar III folder</string>
    <string name="asset_status_missing">Caesar 3 files not yet installed.</string>
    <string name="asset_status_copying">Copying Caesar 3 files…</string>
    <string name="asset_status_ready">Caesar 3 files installed. Ready to use as a live wallpaper.</string>
    <string name="asset_status_error">Copy failed: %1$s</string>

